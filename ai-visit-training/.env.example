# OpenAI-compatible model gateway
DEEPSEEK_API_KEY=replace-with-secret
DEEPSEEK_BASE_URL=https://model-gateway.example.com/v1
DEEPSEEK_MODEL=replace-with-model-name
CHEAT_MODEL=replace-with-model-name

# Flask service
HOST=127.0.0.1
PORT=5000
CORS_ORIGINS=http://localhost:5000
MOCK_MODE=false
ASR_ENABLED=false
# Backward-compatible alias; ASR_ENABLED takes precedence.
VOICE_ENABLED=false
TTS_ENABLED=false
MAX_CONTENT_LENGTH_MB=8
MAX_AUDIO_BYTES=5242880
ASR_DEBUG_AUDIO=false
DEFAULT_TRAINING_ROUNDS=6
MODEL_REQUEST_TIMEOUT_SECONDS=60
MODEL_MAX_RETRIES=1
SESSION_TTL_SECONDS=7200
MAX_SESSIONS=100

# Network proxy; internal model and service hosts must be listed in NO_PROXY.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost,customer-intelligence-api,ai-training

# Optional local knowledge paths
DOC_PATH=./doc
KNOWCARD_PATH=./knowcard_output

# Optional local FunASR
FUNASR_MODEL=paraformer-zh

# Optional iFlytek ASR; leave empty when voice is disabled
XF_APPID=
XF_API_KEY=
XF_API_SECRET=

# Optional Edge TTS
TTS_VOICE=zh-CN-YunxiNeural
TTS_RATE=+5%
TTS_VOLUME=+0%

# Legacy deployment utilities only
DEPLOY_HOST=
DEPLOY_PORT=22
DEPLOY_USER=root
DEPLOY_PASSWORD=
