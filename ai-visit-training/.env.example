# OpenAI-compatible model gateway
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=
CHEAT_MODEL=
TRAINING_MODEL_ENABLE_THINKING=false
TRAINING_MODEL_MAX_TOKENS=1000
ASR_ENABLED=false
ASR_PROVIDER=http
ASR_BASE_URL=http://funasr-service:8000
ASR_REQUEST_TIMEOUT_SECONDS=120
ASR_TIMEOUT_SECONDS=120
ASR_MAX_AUDIO_SECONDS=120
MAX_AUDIO_BYTES=52428800
MAX_CONTENT_LENGTH_MB=52

# Optional semantic retrieval capabilities (reserved only; not used by current code)
EMBEDDING_ENABLED=false
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
RERANK_ENABLED=false
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL=
RERANK_TOP_N=5

# Flask service
HOST=127.0.0.1
PORT=5000
CORS_ORIGINS=http://localhost:5000
MOCK_MODE=true
DEMO_MODE=false
DEMO_SCENE_ID=knowcard/标品/省产品运营中心-安全大脑
TTS_ENABLED=false
TTS_PROVIDER=http
TTS_BASE_URL=http://tts-service:8001
TTS_REQUEST_TIMEOUT_SECONDS=30
TTS_MAX_TEXT_CHARS=500
TTS_MAX_AUDIO_BYTES=20971520
ASR_DEBUG_AUDIO=false
DEFAULT_TRAINING_ROUNDS=6
MODEL_REQUEST_TIMEOUT_SECONDS=60
MODEL_MAX_RETRIES=1
SESSION_TTL_SECONDS=7200
MAX_SESSIONS=100

# Network proxy; internal model and service hosts must be listed in NO_PROXY.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost,customer-intelligence-api,ai-training,funasr-service,tts-service

# Optional local knowledge paths
DOC_PATH=./doc
KNOWCARD_PATH=./knowcard_output

# Historical iFlytek variables are unused by the default HTTP ASR path.
XF_APPID=
XF_API_KEY=
XF_API_SECRET=

# Legacy deployment utilities only
DEPLOY_HOST=
DEPLOY_PORT=22
DEPLOY_USER=root
DEPLOY_PASSWORD=
