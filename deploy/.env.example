# Public entry
GATEWAY_PORT=8080
PUBLIC_ORIGIN=https://visit-assistant.example.com
PORTAL_SOLUTION_URL=https://solution-assistant.example.com/

# Default to Mock until controlled validation is explicitly approved
INTELLIGENCE_MOCK_MODE=true
TRAINING_MOCK_MODE=true

# Internal model gateways (never commit real values)
INTELLIGENCE_MODEL_BASE_URL=
INTELLIGENCE_MODEL_NAME=
INTELLIGENCE_MODEL_API_KEY=
TRAINING_MODEL_BASE_URL=
TRAINING_MODEL_NAME=
TRAINING_MODEL_API_KEY=
TRAINING_MODEL_ENABLE_THINKING=false
TRAINING_MODEL_MAX_TOKENS=1000

# Training data and optional local CPU ASR
AI_TRAINING_IMAGE=deploy-ai-training
FUNASR_IMAGE=deploy-funasr-service
IMAGE_TAG=dev
USE_HOT_COMPOSE=false
TRAINING_KNOWCARD_DIR=../ai-visit-training/knowcard_output
ASR_PROVIDER=disabled
ASR_BASE_URL=http://funasr-service:8000
ASR_REQUEST_TIMEOUT_SECONDS=120
ASR_TIMEOUT_SECONDS=120
ASR_MAX_AUDIO_SECONDS=120
MAX_AUDIO_BYTES=52428800
MAX_CONTENT_LENGTH_MB=52
TTS_ENABLED=false
FUNASR_MODELS_DIR=../models/funasr
FUNASR_DEVICE=cpu
FUNASR_MAX_CONCURRENCY=2
FUNASR_THREADS=16
FUNASR_TIMEOUT_SECONDS=120
FUNASR_MAX_AUDIO_SECONDS=120
FUNASR_MAX_UPLOAD_MB=50
FUNASR_ALLOW_MODEL_DOWNLOAD=false
CUDA_VISIBLE_DEVICES=
DEBIAN_MIRROR=deb.debian.org

# Search and web access
SEARCH_MCP_ENGINE=baidu
SEARCH_SERVICE_BASE_URL=https://www.baidu.com/s
SEARCH_SERVICE_API_KEY=
SEARCH_MCP_TIMEOUT=15
SEARCH_MAX_FETCH_PAGES=80
SEARCH_MAX_CONTENT_CHARS=50000
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost,ai-training,funasr-service,customer-intelligence-api,unified-portal,nginx

# Timeouts and bounded in-memory sessions
INTELLIGENCE_RESEARCH_TIMEOUT_SECONDS=600
TRAINING_CONNECT_TIMEOUT_MS=2000
TRAINING_READ_TIMEOUT_MS=10000
DEFAULT_TRAINING_ROUNDS=6
MODEL_REQUEST_TIMEOUT_SECONDS=60
MODEL_MAX_RETRIES=1
SESSION_TTL_SECONDS=7200
MAX_SESSIONS=100
