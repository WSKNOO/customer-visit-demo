# Public entry
GATEWAY_PORT=8080
PUBLIC_ORIGIN=https://visit-assistant.example.com
PORTAL_SOLUTION_URL=https://solution-assistant.example.com/

# Default to Mock until controlled validation is explicitly approved
INTELLIGENCE_MOCK_MODE=true
TRAINING_MOCK_MODE=true

# Internal model gateways (never commit real values)
INTELLIGENCE_MODEL_BASE_URL=https://internal-model.example.com/v1
INTELLIGENCE_MODEL_NAME=replace-with-model-name
INTELLIGENCE_MODEL_API_KEY=replace-with-secret
TRAINING_MODEL_BASE_URL=https://internal-model.example.com/v1
TRAINING_MODEL_NAME=replace-with-model-name
TRAINING_MODEL_API_KEY=replace-with-secret

# Search and web access
SEARCH_MCP_ENGINE=baidu
SEARCH_SERVICE_BASE_URL=https://www.baidu.com/s
SEARCH_SERVICE_API_KEY=
SEARCH_MCP_TIMEOUT=15
SEARCH_MAX_FETCH_PAGES=80
SEARCH_MAX_CONTENT_CHARS=50000
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost,ai-training,customer-intelligence-api,unified-portal,nginx,internal-model.example.com

# Timeouts and bounded in-memory sessions
INTELLIGENCE_RESEARCH_TIMEOUT_SECONDS=600
TRAINING_CONNECT_TIMEOUT_MS=2000
TRAINING_READ_TIMEOUT_MS=10000
DEFAULT_TRAINING_ROUNDS=6
MODEL_REQUEST_TIMEOUT_SECONDS=60
MODEL_MAX_RETRIES=1
SESSION_TTL_SECONDS=7200
MAX_SESSIONS=100
