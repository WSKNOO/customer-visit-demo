server {
    listen 8080;
    server_name _;
    return 301 https://$host$request_uri;
}

server {
    listen 8443 ssl;
    server_name _;
    ssl_certificate /etc/nginx/certs/server.crt;
    ssl_certificate_key /etc/nginx/certs/server.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_cache shared:TLS:10m;
    client_max_body_size 50m;

    location = /gateway-health { access_log off; default_type application/json; return 200 '{"status":"ok","service":"gateway"}'; }
    location /intelligence-api/ { proxy_pass http://customer-intelligence-api:3001/api/; proxy_connect_timeout 3s; proxy_read_timeout 120s; proxy_set_header Host $host; proxy_set_header X-Forwarded-Proto https; }
    location /intelligence/ { proxy_pass http://customer-intelligence-frontend/; proxy_set_header Host $host; proxy_set_header X-Forwarded-Proto https; }
    location = /api/asr/transcribe { proxy_pass http://ai-training:5000/api/asr/transcribe; proxy_connect_timeout 3s; proxy_read_timeout 150s; proxy_send_timeout 150s; proxy_set_header Host $host; proxy_set_header X-Forwarded-Proto https; }
    location /api/ { proxy_pass http://ai-training:5000/api/; proxy_connect_timeout 3s; proxy_read_timeout 120s; proxy_set_header Host $host; proxy_set_header X-Forwarded-Proto https; }
    location /training/ { proxy_pass http://ai-training:5000/; proxy_set_header Host $host; proxy_set_header X-Forwarded-Proto https; }
    location / { proxy_pass http://unified-portal:8080; proxy_set_header Host $host; proxy_set_header X-Forwarded-Proto https; }
}
