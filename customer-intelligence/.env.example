# Search and model configuration. Copy to .env and inject secrets locally.
SEARCH_MCP_ENGINE=baidu
SEARCH_MCP_PROXY=
SEARCH_MCP_TIMEOUT=15
SEARCH_MCP_DEFAULT_COUNT=10
SEARCH_SERVICE_BASE_URL=https://search-service.example.com/search
SEARCH_SERVICE_API_KEY=replace-with-secret
SEARCH_MAX_FETCH_PAGES=80
SEARCH_MAX_CONTENT_CHARS=50000
SEARCH_MCP_SUMMARIZER_ENABLED=true
SEARCH_MCP_SUMMARIZER_API_BASE=https://model-gateway.example.com/v1
SEARCH_MCP_SUMMARIZER_API_KEY=replace-with-secret
SEARCH_MCP_SUMMARIZER_MODEL=replace-with-model-name
SEARCH_MCP_SUMMARIZER_TEMPERATURE=0.3
SEARCH_MCP_SUMMARIZER_MAX_TOKENS=64000
SEARCH_MCP_SUMMARIZER_MAX_INPUT_CHARS=128000

# Optional semantic retrieval capabilities (reserved only; not used by current code)
EMBEDDING_ENABLED=false
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
RERANK_ENABLED=false
RERANK_BASE_URL=
RERANK_API_KEY=
RERANK_MODEL=
RERANK_TOP_N=5

# Web API
INTELLIGENCE_API_HOST=127.0.0.1
INTELLIGENCE_API_PORT=3001
INTELLIGENCE_CORS_ORIGINS=http://localhost:8006
INTELLIGENCE_MOCK_MODE=false
MOCK_MODE=false
INTELLIGENCE_MAX_BODY_KB=128
INTELLIGENCE_RESEARCH_TIMEOUT_SECONDS=600

# Training integration (service URL is internal; public URL is returned to the browser)
TRAINING_INTEGRATION_ENABLED=false
TRAINING_SERVICE_BASE_URL=http://ai-training:5000
TRAINING_PUBLIC_URL=/training/
TRAINING_CONNECT_TIMEOUT_MS=2000
TRAINING_READ_TIMEOUT_MS=10000

# Unified server proxy. Add internal model/training hosts to NO_PROXY.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost,ai-training,customer-intelligence-api
